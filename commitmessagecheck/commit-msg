#!/bin/bash

commit_msg_file="$1"

if [[ -z "$commit_msg_file" || ! -f "$commit_msg_file" ]]; then
  echo "ERROR: commit message file not provided"
  exit 1
fi

header="$(head -n 1 "$commit_msg_file")"

pattern='^(build|chore|ci|docs|feat|fix|perf|refactor|revert|style|test)(\([a-z]+\))?!?: .+$'

if ! [[ "$header" =~ $pattern ]]; then
  echo "ERROR: Invalid commit message header"
  echo "Found : $header"
  echo "Expected format: type(scope)?: subject"
  exit 1
fi

exit 0
